# Base URL of your n8n instance, ending with /webhook
# Local dev: http://localhost:5678/webhook
# Through ngrok: https://your-subdomain.ngrok-free.dev/webhook
N8N_BASE_URL=https://your-ngrok-subdomain.ngrok-free.dev/webhook
